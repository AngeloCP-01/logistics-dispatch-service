NODE_ENV=development
PORT=3004
LOG_LEVEL=debug
LOG_SERVICE_NAME=dispatch-service

# Postgres (dev compose brings this up on :5437).
DISPATCH_DB_URL=postgresql://dispatch:dispatch@localhost:5437/dispatch?schema=public

# Redis (dev compose / platform logistics-redis).
# NOTE: docker-compose.yml maps dispatch-redis to host port 6380 to avoid clashing
# with the platform logistics-redis on 6379. In a full local run (platform stack up),
# use 6379 (as written below). In isolated mode (only this compose), change to 6380.
REDIS_URL=redis://localhost:6379

# Verifies INBOUND user JWTs (HS256). MUST EQUAL auth-service's AUTH_JWT_SECRET.
JWT_SECRET=change-me-min-32-chars-aaaaaaaaaaaa

# Signs the OUTBOUND service JWT dispatch sends to user-service. MUST EQUAL
# user-service's USER_SERVICE_JWT_SECRET, and MUST DIFFER from JWT_SECRET.
SERVICE_JWT_SECRET=change-me-min-32-chars-bbbbbbbbbbbb

# Where dispatch resolves driver profiles. LOCALLY point at user-service (:3001).
# In real deploys this is the gateway URL.
DISPATCH_USER_SERVICE_URL=http://localhost:3001

# Broker. Platform `logistics-rabbitmq` uses dev/dev.
RABBITMQ_URL=amqp://dev:dev@localhost:5672

# Offer-loop tuning.
DISPATCH_OFFER_TTL_SECONDS=30
DISPATCH_MAX_OFFER_ATTEMPTS=3
